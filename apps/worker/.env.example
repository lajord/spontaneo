# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/spontaneo"

# ── Service IA ────────────────────────────────────────────────────────────────
AI_SERVICE_URL="http://localhost:8000"

# ── Stockage fichiers ─────────────────────────────────────────────────────────
# Chemin absolu vers le dossier uploads partagé avec la web app
# Doit pointer vers le même dossier que UPLOADS_ROOT dans apps/web/.env.local
UPLOADS_ROOT="/srv/spontaneo/uploads"

# ── NeverBounce (validation emails) ──────────────────────────────────────────
NEVER_BOUNCE_API_KEY=

# ── Concurrence ────────────────────────────────────────────────────────────────
ENRICHISSEMENT_CONCURRENCY=5    # Entreprises traitées en parallèle par job
WORKER_CONCURRENCY=10           # Jobs utilisateurs traités en parallèle
