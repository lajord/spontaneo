# ======================
# OVH AI Endpoints (Qwen2.5) — appel IA pour codes NAF
# ======================
OVH_AI_ENDPOINTS_ACCESS_TOKEN=your-ovh-token-here
OVH_AI_BASE_URL=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1
OVH_AI_MODEL=Qwen2.5-VL-72B-Instruct

# ======================
# Google Places API — recherche entreprises par géolocalisation
# ======================
GOOGLE_PLACE_API=your-google-places-api-key

# ======================
# Perplexity API — enrichissement contacts (dirigeant, DRH, emails)
# ======================
PERPLEXITY_API_KEY=your-perplexity-api-key

# ======================
# Nominatim (optionnel) — géocodage OpenStreetMap
# ======================
# NOMINATIM_USER_AGENT=spontaneo/1.0
