generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── BetterAuth tables ─────────────────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          String   @default("user") // "user" | "admin"
  credits       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaigns          Campaign[]
  sessions           Session[]
  accounts           Account[]
  emailConfig        EmailConfig?
  jobs               Job[]
  contactedCompanies ContactedCompany[]
  agentCandidates    AgentCandidate[]
  agentContacts      AgentContact[]
  agentContactDrafts AgentContactDraft[]
  creditPurchases    CreditPurchase[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ── App tables ────────────────────────────────────────────────────────────────

model Campaign {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  jobTitle      String
  sectors       String[]  @default([])
  categories    String[]  @default([])
  granularity   String    @default("moyen")
  location      String
  radius        Int       @default(20)
  cvUrl         String?
  cvData        Json?
  lmText        String?
  startDate     String?
  duration      String?
  prompt        String?
  enrichMode    String    @default("basic")
  status        String    @default("draft")
  autoStart     Boolean   @default(false)
  dailyLimit    Int?
  launchedAt    DateTime?
  sendStartHour Int?      @default(8)
  sendEndHour   Int?      @default(18)
  totalEmails   Int?
  sentCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companies Company[]
  emails    Email[]
  jobs      Job[]
  agentCandidates AgentCandidate[]
  agentContactDrafts AgentContactDraft[]
  creditPurchases    CreditPurchase[]
}

model Company {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name       String
  address    String?
  website    String?
  phone      String?
  sector     String?
  siren      String?
  codeNaf    String?
  source     String?
  score      Int?
  enriched   Json?
  status     String   @default("scraped")
  scrapedAt  DateTime @default(now())

  emails Email[]
}

model Email {
  id            String    @id @default(cuid())
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subject       String
  body          String
  to            String? // adresse email du destinataire (null si inconnue)
  recipientName String? // nom du destinataire (pour affichage)
  generatedLm   String? // LM personnalisée générée pour ce destinataire
  status        String    @default("draft")
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
}

// ── Tracking des contacts (Anti-doublon global) ───────────────────────────────

model ContactedCompany {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String // Nom normalisé de l'entreprise
  domain      String? // Domaine du site web pour vérification supplémentaire
  contactedAt DateTime @default(now())

  @@unique([userId, companyName])
}

// ── Agent Candidates (résultats Agent Deep Search) ───────────────────────────

model AgentCandidate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Identité de l'entreprise
  name        String
  domain      String?  // Domaine extrait de l'URL (pour la déduplication)
  websiteUrl  String?
  city        String?
  description String?

  // Contexte de la recherche (traçabilité)
  source      String?  // 'apollo' | 'google_maps' | 'perplexity' | 'crawl' | etc.
  secteur     String?  // 'cabinets' | 'banques' | 'fonds'
  jobTitle    String?  // Le poste visé ayant généré cette recherche
  location    String?  // La ville / zone de la recherche

  status      String   @default("pending") // pending | enriched | skipped

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts    AgentContact[]
  contactDrafts AgentContactDraft[]

  @@unique([jobId, domain])       // Anti-doublon par run agent
  @@index([userId, status])
  @@index([campaignId, status])
  @@index([jobId, status])
}

model AgentContactDraft {
  id               String   @id @default(cuid())
  agentCandidateId String
  agentCandidate   AgentCandidate @relation(fields: [agentCandidateId], references: [id], onDelete: Cascade)
  userId           String
  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId       String?
  campaign         Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  name             String
  firstName        String?
  lastName         String?
  email            String?
  title            String?
  specialty        String?
  city             String?

  contactType      String   // "personal" | "generic"
  isTested         Boolean  @default(false)

  sourceStage      String   // "3A" | "3B" | "3C"
  sourceTool       String?  // "crawl_url" | "perplexity_search" | ...
  sourceUrl        String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([agentCandidateId])
  @@index([userId])
  @@index([campaignId])
}

// ── Agent Contacts (contacts enrichis lies aux entreprises) ──────────────

model AgentContact {
  id                String   @id @default(cuid())
  agentCandidateId  String
  agentCandidate    AgentCandidate @relation(fields: [agentCandidateId], references: [id], onDelete: Cascade)
  userId            String
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identite du contact
  name              String
  firstName         String?
  lastName          String?
  email             String?
  title             String?
  phone             String?
  linkedin          String?

  // Verification email
  emailStatus       String?  // "valid" | "invalid" | "catchall" | "unknown"
  source            String?  // "apollo" | "perplexity" | "crawl" | "neverbounce"

  // Evaluation IA (quality gate)
  qualityScore      Int?     // 1-10
  qualityReason     String?
  isDecisionMaker   Boolean  @default(false)

  createdAt         DateTime @default(now())

  @@unique([agentCandidateId, email])
  @@index([userId])
}

// ── Background jobs ───────────────────────────────────────────────────────────

model Job {
  id             String    @id @default(cuid())
  pgbossId       String?   @unique
  type           String    @default("campaign_generate") // campaign_generate | agent_search
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  status         String    @default("pending") // pending | running | completed | failed | cancelled
  totalCompanies Int       @default(0)
  processedCount Int       @default(0)
  failedCount    Int       @default(0)
  payload        Json? // links, userMailTemplate, templatePrompt, etc.
  error          String?
  cancelRequestedAt DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  events JobEvent[]
  agentCandidates AgentCandidate[]
}

// Append-only event log — permet le replay SSE via Last-Event-ID (curseur = seq)
model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seq       Int // monotonically increasing per job
  payload   Json // raw SSE event (type, companyId, companyName, emails, ...)
  createdAt DateTime @default(now())

  @@index([jobId, seq])
}

model CreditPurchase {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId              String?
  campaign                Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  credits                 Int
  unitPriceCents          Int
  amountCents             Int
  currency                String    @default("eur")
  status                  String    @default("pending") // pending | completed | expired | failed
  stripeCheckoutSessionId String?   @unique
  stripePaymentIntentId   String?   @unique
  stripeCustomerId        String?
  completedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([campaignId, createdAt])
  @@index([status, createdAt])
}

model EmailConfig {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String // 'gmail' | 'microsoft'
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  oauthEmail   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ── Admin config (singleton) ────────────────────────────────────────────────

model AppConfig {
  id             String @id @default("singleton")
  maxConcurrent  Int    @default(2) // jobs paralleles max
  batchSize      Int    @default(3) // entreprises traitees en parallele par job
  pollIntervalMs Int    @default(15000) // intervalle de polling du worker (ms)

  // Modeles IA par service
  modelEnrichissement  String @default("spark-1-mini")
  modelEnrichissement2 String @default("sonar-pro")
  modelCreationMail    String @default("gpt-5")
  modelCreationLm      String @default("gpt-5")
  modelKeywords        String @default("gpt-5")
  modelCvReader        String @default("Qwen2.5-VL-72B-Instruct")
  modelRanking         String @default("gemini-2.5-flash")
  modelFilter          String @default("sonar-pro")

  // Filtrage IA post-extraction
  filterBatchSize Int @default(1) // entreprises par appel IA filter

  updatedAt DateTime @updatedAt
}
